# Application
APP_ENV=production
APP_SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
APP_DEBUG=false
APP_PORT=8000

# PostgreSQL
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=change-me-strong-password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_TTL=300

# NGINX / SSL
DOMAIN=yourdomain.com
